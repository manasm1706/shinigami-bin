generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  asciiGifs        AsciiGif[]
  messages         Message[]
  memberships      ConversationMember[]
  prophecies       Prophecy[]
  reactions        MessageReaction[]
  ownedCommunities Community[]
  communityMembers CommunityMember[]
}

model Conversation {
  id        String   @id @default(cuid())
  type      String   // "realm" | "dm" | "group"
  name      String?
  realmId   String?
  createdAt DateTime @default(now())

  members  ConversationMember[]
  messages Message[]
  communityChannel CommunityChannel?
}

model ConversationMember {
  id             String   @id @default(cuid())
  userId         String
  conversationId String
  joinedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           String   @default("text") // "text" | "ascii_gif"
  asciiGifId     String?
  createdAt      DateTime @default(now())

  conversation Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User            @relation(fields: [senderId], references: [id], onDelete: Cascade)
  asciiGif     AsciiGif?       @relation(fields: [asciiGifId], references: [id], onDelete: SetNull)
  reactions    MessageReaction[]
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model AsciiGif {
  id         String   @id @default(cuid())
  creatorId  String
  title      String
  frames     String   // JSON array of frame strings
  frameDelay Int      @default(150) // ms per frame
  width      Int      @default(80)
  height     Int      @default(24)
  createdAt  DateTime @default(now())

  creator  User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Prophecy {
  id               String   @id @default(cuid())
  userId           String
  title            String
  date             DateTime
  ominousTitle     String
  ominousDescription String
  severity         String   @default("low") // "low" | "medium" | "high"
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Community {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  icon        String   @default("◆")
  ownerId     String
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  owner    User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members  CommunityMember[]
  channels CommunityChannel[]
}

model CommunityMember {
  id          String   @id @default(cuid())
  communityId String
  userId      String
  role        String   @default("member") // "owner" | "member"
  joinedAt    DateTime @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
}

model CommunityChannel {
  id          String   @id @default(cuid())
  communityId String
  name        String
  description String   @default("")
  createdAt   DateTime @default(now())

  community     Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  conversation  Conversation? @relation(fields: [conversationId], references: [id])
  conversationId String?      @unique
}
